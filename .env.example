# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key. Server-side only — never exposed to the client.
ANTHROPIC_API_KEY=

# Secret for sealing custom-scenario fact sheets (AES-256-GCM). Any long random
# string; generate with: openssl rand -base64 32
SCENARIO_SECRET=

# ── Models (optional; defaults shown) ───────────────────────────────────────
PERSONA_MODEL=claude-haiku-4-5-20251001
CLASSIFIER_MODEL=claude-sonnet-4-6
NARRATIVE_MODEL=claude-sonnet-4-6
GENERATOR_MODEL=claude-sonnet-4-6

# ── Caps / abuse guards (optional; defaults shown) ──────────────────────────
MAX_USER_TURNS=14
MAX_USER_MESSAGE_CHARS=600
PER_IP_DAILY_SESSIONS=15
# Global daily LLM-call ceiling across all IPs — stops a distributed spike the
# per-IP cap cannot. Tune for judging-week traffic vs. budget.
GLOBAL_DAILY_CALL_CAP=5000
GATE_MIN_QUESTIONS=5

# ── Rate limiting (optional; in-memory fallback used if unset) ──────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
